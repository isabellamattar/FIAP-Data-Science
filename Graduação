    {
      "cell_type": "markdown",
      "source": [
        "# Exercício 3: Experimente diferentes variáveis (além de BRP) para prever o PIB, e verifique (ao final) quais produzem um menor erro de previsão"
      ],
      "metadata": {
        "id": "ICSyy7OdR3C5"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "cenarios = {\n",
        "    \"Cenário 1 (Só Pesados)\": ['BRP'],\n",
        "    \"Cenário 2 (Só Leves)\": ['BRL'],\n",
        "    \"Cenário 3 (Leves + Pesados)\": ['BRP', 'BRL'],\n",
        "    \"Cenário 4 (Total)\": ['BRT']\n",
        "}\n",
        "\n",
        "for nome, vars_x in cenarios.items():\n",
        "    # Treino do modelo\n",
        "    modelo = LinearRegression()\n",
        "    modelo.fit(treino[vars_x], treino[['PIB']])\n",
        "\n",
        "    # Previsão\n",
        "    y_prev = modelo.predict(teste[vars_x])\n",
        "    y_real = teste[['PIB']].values\n",
        "\n",
        "    # Erro Médio Absoluto (MAE)\n",
        "    erro = mean_absolute_error(y_real, y_prev)\n",
        "    print(f\"{nome} -> Erro Médio: {erro:.2f}\")"
      ],
