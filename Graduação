      "source": [
        "# Experimentando 12 meses de teste\n",
        "previsao_meses = 12\n",
        "treino = df.iloc[0:(len(df)-previsao_meses)]\n",
        "teste = df.iloc[(len(df)-previsao_meses):]\n",
